# ============================================
# Datathon Fase 05 - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# OpenAI / LLM (OPCIONAL - agente e RAG funcionam sem, com fallback local)
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.0

# Embedding Mode: "local" (sentence-transformers, gratuito) ou "openai" (requer créditos)
EMBEDDING_MODE=local

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=datathon-fase05

# Vector Store (ChromaDB)
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# Knowledge Base
KNOWLEDGE_BASE_DIR=./data/knowledge_base

# Langfuse (Observabilidade LLM - opcional)
# LANGFUSE_PUBLIC_KEY=your-public-key
# LANGFUSE_SECRET_KEY=your-secret-key
# LANGFUSE_HOST=https://cloud.langfuse.com

# API
API_HOST=0.0.0.0
API_PORT=8000

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Security
PII_DETECTION_LANGUAGE=pt
MAX_INPUT_LENGTH=4096
